server {
    listen 80;
    server_name localhost; # TODO adapt this if we use a custom domain

    # Django static files (collected via collectstatic)
    location /static/ {
        alias /usr/share/nginx/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # API requests -> Django backend
    location /api/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host {{ host_header }}; # TODO adapt this if we use a custom domain
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # OIDC auth requests -> Django backend
    location /oidc/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host {{ host_header }}; # TODO adapt this if we use a custom domain
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Django admin -> Django backend
    location /admin/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host {{ host_header }}; # TODO adapt this if we use a custom domain
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Django metrics -> Django backend
    location /metrics {
        proxy_pass http://backend:8000;
        proxy_set_header Host {{ host_header }}; # TODO adapt this if we use a custom domain
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /grafana {
        proxy_pass http://grafana:3000;
        proxy_set_header Host {{ host_header }}; # TODO adapt this if we use a custom domain
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Vite-built SPA - serve index.html for all unmatched routes
    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;

        # Cache busting: Vite hashes asset filenames
        location /assets/ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }
}

